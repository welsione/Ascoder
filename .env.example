# ===========================================
# Ascoder Docker Compose Configuration
# Copy this file to .env and fill in values
# ===========================================

# --- Application ---
# Open http://localhost:${APP_PORT} after startup.
APP_PORT=5173

# --- Image Registry Mirror (optional) ---
# 如果服务器在国内拉取 ghcr.io 镜像慢，可配置镜像前缀（不要带末尾斜杠），例如：
#   ASCODER_IMAGE_PREFIX=ghcr.nju.edu.cn
# 默认留空则走官方 ghcr.io。
ASCODER_IMAGE_PREFIX=

# --- MySQL ---
MYSQL_USER=ascoder
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

# --- LLM Provider ---
# 决定后端装配哪个 ChatModelFactory：database / agentscope。
# database 模式下，LLM API Key / Base URL / 模型 ID 等供应商参数必须
# 在「设置 → 模型供应商」页面手动添加；不再通过环境变量配置。
LLM_PROVIDER=database

# --- API Key Encryption ---
# AES-256 加密密钥（Base64 编码的 32 字节），用于加密存储 LLM provider 的 API Key 等敏感数据。
# 未配置时，install.sh / deploy.sh 会自动生成并写入本文件；也可手动生成：openssl rand -base64 32
# 注意：密钥变更后已加密的数据将无法解密，生产环境务必妥善保管；切勿提交到 Git 仓库。
ASCODER_ENCRYPTION_KEY=
# （以下运行时调参也可以省略，统一在「设置 → 通用设置」里配置）
AGENT_MAX_ITERS=12
AGENT_SSE_TIMEOUT_SECONDS=600

# --- CodeGraph ---
CODEGRAPH_EXECUTABLE=codegraph
CODEGRAPH_TIMEOUT_SECONDS=300
CODEGRAPH_INDEX_TIMEOUT_SECONDS=3600

# --- Git ---
GIT_TIMEOUT_SECONDS=120

# --- Git HTTPS Proxy (optional) ---
# If the container's Git (GnuTLS) cannot complete TLS handshake with your Git server,
# you have two proxy options:
#
# Option A: TLS termination proxy (recommended for GnuTLS incompatibility)
#   1. Start the proxy: python3 git-tls-proxy.py 8443
#   2. Set: GIT_TLS_PROXY=http://host.docker.internal:8443
#   The proxy runs on the host (OpenSSL) and forwards as HTTPS to the target.
#   To auto-start on macOS: cp backend/docker/com.ascoder.tls-proxy.plist ~/Library/LaunchAgents/
#                            launchctl load ~/Library/LaunchAgents/com.ascoder.tls-proxy.plist
#
# Option B: HTTP CONNECT proxy
#   1. Start the proxy: python3 git-https-proxy.py 8443
#   2. Set: GIT_HTTP_PROXY=http://host.docker.internal:8443
GIT_HTTP_PROXY=
GIT_TLS_PROXY=

# --- Git HTTPS Token (optional) ---
# If your repos require authentication, set credentials here.
# The backend will write them into the container's git credential store.
# GIT_TOKEN: the password or personal access token.
# GIT_USERNAME: the username (default: "git", which works for GitHub/GitLab tokens;
#   for password-based auth, use your actual username).
# For GitHub: use a Personal Access Token with repo scope, GIT_USERNAME=git.
# For GitLab: use a Personal Access Token with read_repository scope, GIT_USERNAME=oauth2.
# For private Git servers with password auth: use your actual username and password.
GIT_TOKEN=
GIT_USERNAME=git

# --- Git Extra Hosts (optional) ---
# Comma- or space-separated list of extra git hosts (in addition to
# github.com, gitlab.com, gitee.com) that should receive the GIT_TOKEN
# in the container's git credential store.
# Wildcards (*.example.com) are NOT supported — git credential store
# does not match globs. To support host patterns, see Phase 2 (planned).
# Example: GIT_EXTRA_HOSTS=git.example.com,gitlab.internal.corp
GIT_EXTRA_HOSTS=

# --- Windows Users ---
# - Run from PowerShell (Admin recommended for first install)
# - Ensure Docker Desktop is installed and the WSL2 backend is enabled
#   (Settings -> General -> Use WSL2 based engine)
# - Project path should be under C:\Users\<you>\... (avoid network drives)
# - Use forward slashes in paths inside .env (e.g. C:/Users/you/repos)
# - If the script blocks: powershell -ExecutionPolicy Bypass -File .\installer\install.ps1

# --- SSH Access for Private Repos (optional) ---
# To mount SSH keys for git clone, use the SSH override file:
#   docker compose -f docker-compose.yml -f docker-compose.ssh.yml up
# This mounts ~/.ssh/id_rsa, config, and known_hosts into the container.

# --- Host Repo Mount (optional) ---
# To mount repos from the host instead of cloning:
#   1. Set HOST_REPO_PATH below
#   2. Run: docker compose -f docker-compose.yml -f docker-compose.host-repos.yml up
# HOST_REPO_PATH=/path/to/your/repos

# --- JVM Options ---
JVM_OPTS=-Xmx512m -Xms256m
